<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0E0A">

    <!-- Camera Preview -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Top Bar -->
    <ImageButton
        android:id="@+id/btnClose"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_margin="16dp"
        android:background="@drawable/circle_dark_bg"
        android:src="@drawable/ic_close"
        android:tint="#FFFFFF"
        android:contentDescription="Close"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageButton
        android:id="@+id/btnFlash"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_margin="16dp"
        android:background="@drawable/circle_dark_bg"
        android:src="@drawable/ic_flash"
        android:tint="#FFFFFF"
        android:contentDescription="Flash"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnHelp" />

    <ImageButton
        android:id="@+id/btnHelp"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_margin="16dp"
        android:background="@drawable/circle_dark_bg"
        android:src="@drawable/ic_help"
        android:tint="#FFFFFF"
        android:contentDescription="Help"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Scan Box -->
    <View
        android:id="@+id/scanBox"
        android:layout_width="220dp"
        android:layout_height="280dp"
        android:background="@drawable/scan_overlay"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Hint Text -->
    <TextView
        android:id="@+id/tvHint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Place the plant in focus"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintTop_toTopOf="@id/scanBox"
        app:layout_constraintBottom_toBottomOf="@id/scanBox"
        app:layout_constraintStart_toStartOf="@id/scanBox"
        app:layout_constraintEnd_toEndOf="@id/scanBox" />

    <!-- Zoom Buttons -->
    <ImageButton
        android:id="@+id/btnZoomIn"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="80dp"
        android:background="@drawable/circle_dark_bg"
        android:src="@drawable/ic_zoom_in"
        android:tint="#FFFFFF"
        android:contentDescription="Zoom in"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomBar" />

    <ImageButton
        android:id="@+id/btnZoomOut"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="36dp"
        android:background="@drawable/circle_dark_bg"
        android:src="@drawable/ic_zoom_out"
        android:tint="#AAFFFFFF"
        android:contentDescription="Zoom out"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomBar" />

    <!-- Bottom Bar -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="0dp"
        android:layout_height="120dp"
        android:background="#000000"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Gallery Button -->
        <ImageButton
            android:id="@+id/btnGallery"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="@drawable/rounded_dark_bg"
            android:src="@drawable/ic_gallery"
            android:tint="#99FFFFFF"
            android:contentDescription="Gallery" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <!-- Capture Button -->
            <FrameLayout
                android:id="@+id/btnCapture"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@drawable/capture_button_bg">
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="IDENTIFY"
                android:textColor="#2ECC71"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:fontFamily="sans-serif-medium" />

        </LinearLayout>

        <View
            android:layout_width="52dp"
            android:layout_height="52dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
