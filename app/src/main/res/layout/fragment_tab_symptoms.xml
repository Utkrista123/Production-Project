<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#080E08">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Disease Badge -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/badge_bg_dark"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp"
            android:layout_marginBottom="20dp">

            <View
                android:layout_width="9dp"
                android:layout_height="9dp"
                android:background="@drawable/dot_yellow"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tvDiseaseType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fungal Disease"
                android:textColor="#FFC107"
                android:textSize="13sp"
                android:fontFamily="sans-serif-bold" />
        </LinearLayout>

        <!-- Symptom Analysis Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Symptom Analysis"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:fontFamily="sans-serif-bold"
            android:layout_marginBottom="10dp" />

        <!-- Cause Description -->
        <TextView
            android:id="@+id/tvCause"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Disease cause description here."
            android:textColor="#CCCCCC"
            android:textSize="14sp"
            android:lineSpacingMultiplier="1.7"
            android:layout_marginBottom="20dp" />

        <!-- Symptoms List Container -->
        <LinearLayout
            android:id="@+id/symptomsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp" />

        <!-- Severity Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Severity Indicators"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:fontFamily="sans-serif-bold"
            android:layout_marginBottom="16dp" />

        <!-- Severity Bars -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">
                <TextView
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:text="Spread rate"
                    android:textColor="#AAAAAA"
                    android:textSize="13sp" />
                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bar_bg_dark">
                    <View
                        android:id="@+id/barSpread"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:background="@drawable/bar_fill_yellow" />
                </FrameLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">
                <TextView
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:text="Crop damage"
                    android:textColor="#AAAAAA"
                    android:textSize="13sp" />
                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bar_bg_dark">
                    <View
                        android:id="@+id/barDamage"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:background="@drawable/bar_fill_orange" />
                </FrameLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:text="Treatability"
                    android:textColor="#AAAAAA"
                    android:textSize="13sp" />
                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bar_bg_dark">
                    <View
                        android:id="@+id/barTreat"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:background="@drawable/bar_fill_green" />
                </FrameLayout>
            </LinearLayout>

        </LinearLayout>

        <!-- Recommended Action Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/treatment_card_dark"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/tvRecommendedTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recommended Action"
                android:textColor="#2ECC71"
                android:textSize="14sp"
                android:fontFamily="sans-serif-bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvRecommendedAction"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Treatment details here."
                android:textColor="#AAFFAA"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.6" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>