<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Disease Badge -->
        <LinearLayout
            android:id="@+id/diseaseBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/badge_bg"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:layout_marginBottom="16dp">

            <View
                android:id="@+id/badgeDot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/dot_yellow"
                android:layout_marginEnd="6dp" />

            <TextView
                android:id="@+id/tvDiseaseType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fungal Disease"
                android:textColor="#856404"
                android:textSize="12sp"
                android:fontFamily="sans-serif-bold" />
        </LinearLayout>

        <!-- Symptom Analysis Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Symptom Analysis"
            android:textColor="#000000"
            android:textSize="14sp"
            android:fontFamily="sans-serif-bold"
            android:layout_marginBottom="8dp" />

        <!-- Cause Description -->
        <TextView
            android:id="@+id/tvCause"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Disease cause description here."
            android:textColor="#555555"
            android:textSize="13sp"
            android:lineSpacingMultiplier="1.6"
            android:layout_marginBottom="16dp" />

        <!-- Symptoms Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Key Symptoms"
            android:textColor="#000000"
            android:textSize="14sp"
            android:fontFamily="sans-serif-bold"
            android:layout_marginBottom="8dp" />

        <!-- Symptoms List Container -->
        <LinearLayout
            android:id="@+id/symptomsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp" />

        <!-- Severity Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Severity Indicators"
            android:textColor="#000000"
            android:textSize="14sp"
            android:fontFamily="sans-serif-bold"
            android:layout_marginBottom="12dp" />

        <!-- Severity Bars -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">
                <TextView
                    android:layout_width="90dp"
                    android:layout_height="wrap_content"
                    android:text="Spread rate"
                    android:textColor="#888888"
                    android:textSize="12sp" />
                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bar_bg">
                    <View
                        android:id="@+id/barSpread"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:background="@drawable/bar_fill_yellow" />
                </FrameLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">
                <TextView
                    android:layout_width="90dp"
                    android:layout_height="wrap_content"
                    android:text="Crop damage"
                    android:textColor="#888888"
                    android:textSize="12sp" />
                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bar_bg">
                    <View
                        android:id="@+id/barDamage"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:background="@drawable/bar_fill_orange" />
                </FrameLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="90dp"
                    android:layout_height="wrap_content"
                    android:text="Treatability"
                    android:textColor="#888888"
                    android:textSize="12sp" />
                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bar_bg">
                    <View
                        android:id="@+id/barTreat"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:background="@drawable/bar_fill_green" />
                </FrameLayout>
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</ScrollView>